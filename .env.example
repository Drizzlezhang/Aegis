# ═══════════════════════════════════════════════════════════════
# Aegis — 私有部署回测决策助手
# 复制此文件为 .env 并填入真实值
# ═══════════════════════════════════════════════════════════════

# ─── 必填 ────────────────────────────────────────────────────

# LLM API（OpenAI 兼容接口）
AEGIS_LLM_BASE_URL=https://api.openai.com/v1
AEGIS_LLM_API_KEY=sk-your-key-here

# ─── 可选 ────────────────────────────────────────────────────

# LLM
AEGIS_LLM_DEFAULT_MODEL=gpt-4o-mini
AEGIS_LLM_TIMEOUT_SECONDS=60
AEGIS_LLM_MONTHLY_BUDGET_USD=200.0

# 运行模式
AEGIS_PROFILE=development          # development | production
AEGIS_STRICT_VALIDATION=false      # true = 缺必填 key 时启动失败

# 数据源
ALPHA_VANTAGE_API_KEY=

# Reddit 情绪（可选）
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Aegis/1.0

# 服务端口
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Docker
COMPOSE_PROJECT_NAME=aegis
