# Aegis-Trader 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# 项目基础配置
# ============================================

# 项目环境: development, testing, production
AEGIS_ENVIRONMENT=development

# 调试模式 (生产环境建议关闭)
AEGIS_DEBUG=false

# 日志级别: DEBUG, INFO, WARNING, ERROR
AEGIS_LOG_LEVEL=INFO

# ============================================
# 数据源配置
# ============================================

# Yahoo Finance 数据源 (默认启用)
AEGIS_DATA_SOURCE__YFINANCE_ENABLED=true

# Alpha Vantage 数据源 (备用)
AEGIS_DATA_SOURCE__ALPHA_VANTAGE_ENABLED=false
AEGIS_DATA_SOURCE__ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Longbridge (长桥) 数据源 (港股/A股)
# 注册: https://open.longbridgeapp.com/
AEGIS_DATA_SOURCE__LONGBRIDGE_ENABLED=false

# Longbridge API 凭证 (如启用长桥数据源则必需)
LONGBRIDGE_APP_KEY=your_longbridge_app_key
LONGBRIDGE_APP_SECRET=your_longbridge_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_longbridge_access_token

# Futu (富途) 数据源 (港股/A股/美股)
# 需要安装富途牛牛客户端并启用 OpenD 服务
# pip install futu-api
AEGIS_DATA_SOURCE__FUTU_ENABLED=false

# Futu OpenD 连接地址 (本地服务)
FUTU_OPEND_ADDRESS=127.0.0.1
FUTU_OPEND_PORT=11111

# Tiger Trade (老虎证券) 数据源 (美股/港股/A股)
# 注册: https://www.itiger.com/ 并申请 OpenAPI
# pip install tigeropen
AEGIS_DATA_SOURCE__TIGER_ENABLED=false

# Tiger OpenAPI 凭证
TIGER_ACCOUNT_ID=your_tiger_account_id
TIGER_PRIVATE_KEY=your_tiger_private_key

# 数据缓存时间 (秒)
AEGIS_DATA_SOURCE__CACHE_TTL_SECONDS=300

# ============================================
# LLM 配置
# ============================================

# LLM 提供商: deepseek, glm, kimi, gemini, minimax
AEGIS_LLM__PROVIDER=deepseek

# 推理模型 (统一使用 deepseek-v3.2)
AEGIS_LLM__REASONING_MODEL=deepseek-v3.2

# 长上下文模型
AEGIS_LLM__LONG_CONTEXT_MODEL=gemini-pro

# 快速响应模型
AEGIS_LLM__QUICK_MODEL=minimax-2.7

# 代码生成模型
AEGIS_LLM__CODE_MODEL=glm5.1

# LLM API 基础 URL (可选，使用提供商默认)
# AEGIS_LLM__API_BASE_URL=https://api.deepseek.com

# LLM API 密钥 (必需)
AEGIS_LLM__API_KEY=your_llm_api_key_here

# ============================================
# 算法配置
# ============================================

# 成交量分布 bins 数量
AEGIS_ALGORITHM__VOLUME_PROFILE_BINS=100

# 价值区域百分比 (0.0-1.0)
AEGIS_ALGORITHM__VALUE_AREA_PERCENTAGE=0.7

# GEX 计算方法: simplified, black_scholes
AEGIS_ALGORITHM__GEX_CALCULATION_METHOD=simplified

# PE Band 百分位数
AEGIS_ALGORITHM__PE_BAND_PERCENTILES=0.1,0.25,0.5,0.75,0.9

# 记忆系统配置
# 默认生产 Docker slim 镜像仅启用 SQLite 持久化，不包含 chromadb / sentence-transformers。
# 如需语义检索，请在非 slim 环境额外安装 `.[memory]` 依赖。
# 未安装 memory extras 时，历史记录与 notes 仍可用，semantic search 会降级返回空结果或 unavailable stats。
# ============================================

# 存储类型: sqlite, postgres, chroma
AEGIS_MEMORY__STORAGE_TYPE=sqlite

# SQLite 数据库路径
AEGIS_MEMORY__SQLITE_PATH=~/.aegis-trader/memory.db

# 向量维度
AEGIS_MEMORY__VECTOR_DIMENSION=384

# 最大记忆条目数
AEGIS_MEMORY__MAX_MEMORY_ENTRIES=10000

# ============================================
# Web 界面配置
# ============================================

# 启用 Web 界面
AEGIS_WEB__ENABLED=true

# Web 服务器主机
AEGIS_WEB__HOST=0.0.0.0

# Web 服务器端口
AEGIS_WEB__PORT=3000

# API 服务器端口
AEGIS_WEB__API_PORT=8000

# ============================================
# 代理配置
# ============================================

# 启用数据采集代理
AEGIS_AGENT__DATA_HARVESTER_ENABLED=true

# 启用量化大脑代理
AEGIS_AGENT__QUANT_BRAIN_ENABLED=true

# 启用策略执行代理
AEGIS_AGENT__STRATEGY_EXEC_ENABLED=true

# 启用记忆系统代理
AEGIS_AGENT__AEGIS_MEMORY_ENABLED=true

# 最大并发代理数
AEGIS_AGENT__MAX_CONCURRENT_AGENTS=4

# ============================================
# 核心标的自定义
# ============================================

# 核心标的列表 (逗号分隔)
AEGIS_CORE_SYMBOLS=QQQ,SPY,NVDA,MSFT,AAPL,KO,PLTR,NFLX,INTC,TSM,TSLA

# ============================================
# 策略配置
# ============================================

# LEAPS 最小到期天数 (~10个月)
AEGIS_MIN_LEAPS_DAYS_TO_EXPIRY=300

# Call 期权 Delta 范围 (逗号分隔)
AEGIS_CALL_DELTA_RANGE=0.6,0.8

# 支撑位距离阈值 (百分比)
AEGIS_SUPPORT_DISTANCE_THRESHOLD=0.02

# ============================================
# 路径配置 (通常不需要修改)
# ============================================

# 技能目录 (多个用逗号分隔)
# AEGIS_SKILL_DIRS=skills

# 数据目录
# AEGIS_DATA_DIR=~/.aegis-trader/data

# 缓存目录
# AEGIS_CACHE_DIR=~/.aegis-trader/cache

# 日志目录
# AEGIS_LOG_DIR=~/.aegis-trader/logs

# ============================================
# 高级配置 (可选)
# ============================================

# 数据库连接 (如果使用 PostgreSQL)
# AEGIS_DATABASE_URL=postgresql://user:password@localhost/aegis_trader

# Redis 连接 (如果使用缓存)
# AEGIS_REDIS_URL=redis://localhost:6379/0

# 代理设置 (如果需要)
# AEGIS_HTTP_PROXY=http://proxy.example.com:8080
# AEGIS_HTTPS_PROXY=http://proxy.example.com:8080

# ============================================
# 安全配置
# ============================================

# JWT 密钥 (如果使用身份验证)
# AEGIS_JWT_SECRET=your_jwt_secret_here

# CORS 允许的来源 (逗号分隔)
# AEGIS_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# 使用说明
# ============================================

# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 编辑 .env 文件，填写实际的 API 密钥等配置
#
# 3. 环境变量命名规则:
#    - 前缀: AEGIS_
#    - 嵌套配置使用双下划线分隔: AEGIS_LLM__API_KEY
#    - 列表值用逗号分隔: AEGIS_CORE_SYMBOLS=QQQ,SPY
#
# 4. 优先级: 环境变量 > .env 文件 > 代码默认值
#
# 5. 生产环境注意事项:
#    - 将 .env 文件添加到 .gitignore
#    - 使用安全的密钥管理服务
#    - 定期轮换 API 密钥