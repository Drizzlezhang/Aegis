# ═══════════════════════════════════════════════════════════════
# Aegis-Trader Environment Configuration
# Copy this file to .env and fill in required values
# ═══════════════════════════════════════════════════════════════

# ─── Required ────────────────────────────────────────────────

# Authentication (min 16 chars, generate: python -c "import secrets; print(secrets.token_hex(32))")
AUTH_JWT_SECRET=

# LLM Provider (at least one required)
LLM_API_KEY=
# LLM_OPENAI_API_KEY=
# LLM_ANTHROPIC_API_KEY=

# ─── Optional ────────────────────────────────────────────────

# Application
AEGIS_PROFILE=production          # development | production
AEGIS_STRICT_VALIDATION=false     # true = crash on missing config

# LLM
LLM_DEFAULT_PROVIDER=openai       # openai | anthropic | deepseek | groq | local
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Scheduler
SCHEDULER_DAILY_RUN_TIME=09:30    # HH:MM for daily analysis
SCHEDULER_TRACKING_TIME=16:30     # HH:MM for tracking update

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Data Sources
YFINANCE_TIMEOUT=30
ALPHA_VANTAGE_API_KEY=

# Server
API_HOST=0.0.0.0
API_PORT=8001
FRONTEND_URL=http://localhost:3000

# Docker
COMPOSE_PROJECT_NAME=aegis-trader
